{
  "rewrites": [
    { "source": "/crm", "destination": "https://tn-crm.vercel.app/crm" },
    { "source": "/crm/", "destination": "https://tn-crm.vercel.app/crm" },
    { "source": "/crm/funkcje", "destination": "https://tn-crm.vercel.app/crm/funkcje" },
    { "source": "/crm/funkcje/", "destination": "https://tn-crm.vercel.app/crm/funkcje" },
    { "source": "/crm/case-study/getmypermit", "destination": "https://tn-crm.vercel.app/crm/case-study/getmypermit" },
    { "source": "/crm/case-study/getmypermit/", "destination": "https://tn-crm.vercel.app/crm/case-study/getmypermit" }
  ],
  "redirects": [
    { "source": "/zwolnie", "destination": "/zwolnie/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/zapisy/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
